# Copy these values into your local shell or an ignored local environment file.
# Never commit the real API token, private executable paths, credentials, or session data.

HEPHAESTUS_KERNEL_URL=http://127.0.0.1:4000
HEPHAESTUS_API_TOKEN=replace-with-private-local-kernel-token

# This must point to a thin adapter executable that:
# 1. reads one efesto.hermes-mission.v1 JSON object from stdin;
# 2. invokes the user's authentic Hermes runtime;
# 3. writes exactly one JSON object to stdout: {"findings":[...]};
# 4. sends logs only to stderr and exits non-zero on failure.
HEPHAESTUS_HERMES_COMMAND=/absolute/path/to/hermes-efesto-adapter

# Optional adapter arguments. Must be a JSON array of strings.
HEPHAESTUS_HERMES_ARGS_JSON=[]
