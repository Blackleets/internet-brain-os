{
  "name": "internet-brain-os",
  "version": "1.0.0",
  "description": "Internet Brain OS - A local-first AI web intelligence system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "hermes:attack-smoke": "node scripts/hermes-idempotency-attack-test.mjs",
    "hermes:efesto-adapter": "node scripts/hermes-efesto-adapter.mjs",
    "hermes:ingest-agent": "node scripts/hermes-ingest-agent-output.mjs",
    "hermes:smoke": "node scripts/hermes-smoke-test.mjs",
    "hermes:scan-sensitive": "node scripts/hermes-sensitive-data-scan.mjs",
    "hermes:validate-agent": "node scripts/hermes-validate-agent-output.mjs",
    "kernel:serve": "node apps/local-kernel/one-click-kernel.mjs",
    "kernel:serve:legacy": "node apps/local-kernel/server.mjs",
    "hermes:mission-worker": "node apps/local-kernel/hermes-mission-worker.mjs",
    "hermes:worker:doctor": "node scripts/hermes-worker-doctor.mjs",
    "orchestrator": "node scripts/orchestrator-cli.mjs",
    "replay-lab:api-smoke": "node scripts/replay-lab-api-smoke.mjs",
    "resume": "node scripts/project-resume.mjs",
    "test": "vitest run --passWithNoTests",
    "verify:first-run": "pnpm typecheck && pnpm test && pnpm build && pnpm hermes:validate-agent examples/hermes-agent-run-output.sample.json && pnpm hermes:validate-agent --native-jsonl examples/hermes-native-log.sample.jsonl && pnpm hermes:smoke && pnpm hermes:attack-smoke && pnpm replay-lab:api-smoke",
    "typecheck": "tsc -b --pretty false"
  },
  "packageManager": "pnpm@11.11.0",
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.11"
  }
}
